{
  "tasks": {
    "dev:db": "mongod --dbpath ./devdb",
    "dev:api": "deno run -A --watch main.ts",
    "dev:ingest": "deno run -A --watch ingest.ts",
    "cleanup:orphan-crosspost-reply-records": "deno run -A scripts/delete_orphan_crosspost_reply_records.ts",
    "compact:record-collection": "deno run -A scripts/compact_record_collection.ts",
    "reindex:record-collection": "deno run -A scripts/compact_record_collection.ts",
    "dev": {
      "dependencies": ["dev:db", "dev:api", "dev:ingest"]
    },
    "codegen": "deno run -A jsr:@atp/lex@^0.1.0-alpha.9 build",
    "start": "deno run -A main.ts",
    "docker-dev": "docker compose -f compose.dev.yaml up --build --watch"
  },
  "imports": {
    "@atp/bytes": "jsr:@atp/bytes@^0.1.0-alpha.3",
    "@atp/common": "jsr:@atp/common@^0.1.0-alpha.12",
    "@atp/crypto": "jsr:@atp/crypto@^0.1.0-alpha.3",
    "@atp/identity": "jsr:@atp/identity@^0.1.0-alpha.3",
    "@atp/lex": "jsr:@atp/lex@^0.1.0-alpha.11",
    "@atp/lexicon": "jsr:@atp/lexicon@^0.1.0-alpha.4",
    "@atp/repo": "jsr:@atp/repo@^0.1.0-alpha.7",
    "@atp/sync": "jsr:@atp/sync@^0.1.0-alpha.12",
    "@atp/syntax": "jsr:@atp/syntax@^0.1.0-alpha.2",
    "@atp/xrpc": "jsr:@atp/xrpc@^0.1.0-alpha.7",
    "@atp/xrpc-server": "jsr:@atp/xrpc-server@^0.1.0-alpha.12",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "dotenv": "npm:dotenv@^17.4.2",
    "hono": "jsr:@hono/hono@^4.12.15",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "jose": "npm:jose@^6.2.3",
    "mongoose": "npm:mongoose@^9.6.1",
    "p-queue": "npm:p-queue@^9.2.0",
    "mongodb-memory-server-core": "npm:mongodb-memory-server-core@^11.1.0",
    "structured-headers": "npm:structured-headers@^2.0.2"
  },
  "test": {
    "permissions": {
      "env": true,
      "read": true,
      "write": true,
      "net": true,
      "run": true,
      "sys": true
    }
  }
}
