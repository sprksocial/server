{
  "tasks": {
    "dev": "deno run -A --watch main.ts",
    "codegen": "deno run -A jsr:@atp/lex-cli@^0.1.0-alpha.1 gen-server -o ./lex -i ./lexicons",
    "start": "deno run -A --env-file main.ts",
    "docker-dev": "docker compose -f compose.dev.yaml up --build --watch"
  },
  "imports": {
    "@atp/common": "jsr:@atp/common@^0.1.0-alpha.2",
    "@atp/crypto": "jsr:@atp/crypto@^0.1.0-alpha.1",
    "@atp/lexicon": "jsr:@atp/lexicon@^0.1.0-alpha.1",
    "@atp/syntax": "jsr:@atp/syntax@^0.1.0-alpha.1",
    "@atp/xrpc": "jsr:@atp/xrpc@^0.1.0-alpha.2",
    "@atp/xrpc-server": "jsr:@atp/xrpc-server@^0.1.0-alpha.1",
    "@atproto/identity": "npm:@atproto/identity@^0.4.9",
    "@atproto/repo": "npm:@atproto/repo@^0.8.5",
    "@atproto/sync": "npm:@atproto/sync@^0.1.30",
    "@logtape/logtape": "jsr:@logtape/logtape@^1.0.4",
    "@logtape/pretty": "jsr:@logtape/pretty@^1.1.0-dev.333+b25e634b",
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "dotenv": "npm:dotenv@^17.2.1",
    "hono": "jsr:@hono/hono@^4.9.1",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@atproto/api": "npm:@atproto/api@^0.14.22",
    "jose": "npm:jose@^6.0.12",
    "mongoose": "npm:mongoose@^8.17.1",
    "multiformats": "npm:multiformats@^9.9.0",
    "p-queue": "npm:p-queue@^8.1.0"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "unstable": ["sloppy-imports"]
}
