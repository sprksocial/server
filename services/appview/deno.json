{
  "tasks": {
    "dev": "deno run -A --watch main.ts",
    "codegen": "deno run -A jsr:@sprk/lex-cli@^0.2.0 gen-server --hono-import hono --yes ./lexicon ../../lexicons",
    "start": "deno run --allow-net --allow-env --env-file --allow-sys --allow-read --allow-ffi main.ts",
    "docker-dev": "docker compose -f compose.dev.yaml up --build --watch"
  },
  "imports": {
    "@atproto/repo": "npm:@atproto/repo@^0.8.5",
    "@atproto/sync": "npm:@atproto/sync@^0.1.30",
    "@atproto/xrpc": "npm:@atproto/xrpc@^0.7.1",
    "@logtape/logtape": "jsr:@logtape/logtape@^1.0.4",
    "@logtape/pretty": "jsr:@logtape/pretty@^1.1.0-dev.333+b25e634b",
    "dotenv": "npm:dotenv@^17.2.1",
    "hono": "jsr:@hono/hono@^4.9.1",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@atproto/api": "npm:@atproto/api@^0.14.22",
    "@atproto/common": "npm:@atproto/common@^0.4.11",
    "@atproto/crypto": "npm:@atproto/crypto@^0.4.4",
    "@atproto/identity": "npm:@atproto/identity@^0.4.8",
    "@atproto/lexicon": "npm:@atproto/lexicon@^0.4.12",
    "@atproto/syntax": "npm:@atproto/syntax@^0.3.4",
    "@sprk/xrpc-server": "jsr:@sprk/xrpc-server@^0.2.0",
    "jose": "npm:jose@^6.0.12",
    "key-encoder": "npm:key-encoder@^2.0.3",
    "mongoose": "npm:mongoose@^8.17.1",
    "multiformats": "npm:multiformats@^9.9.0",
    "p-queue": "npm:p-queue@^8.1.0",
    "pino": "npm:pino@^8.21.0",
    "pino-pretty": "npm:pino-pretty@^13.1.1",
    "ws": "npm:ws@^8.18.3"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "unstable": [
    "sloppy-imports"
  ]
}
