{
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-sys --allow-read --allow-ffi --inspect --watch main.ts",
    "codegen": "deno run -A jsr:@sprk/lex-cli@^0.1.5 gen-server --hono-import hono --yes ./lexicon ../../lexicons",
    "start": "deno run --allow-net --allow-env --allow-sys --allow-read --allow-ffi main.ts",
    "docker-dev": "docker compose -f compose.dev.yaml up --build --watch"
  },
  "imports": {
    "@atproto/repo": "npm:@atproto/repo@^0.8.4",
    "@atproto/xrpc": "npm:@atproto/xrpc@^0.7.0",
    "@atproto/xrpc-server": "npm:@atproto/xrpc-server@^0.7.19",
    "dotenv": "npm:dotenv@^17.0.0",
    "hono": "jsr:@hono/hono@^4.7.10",
    "@std/encoding": "jsr:@std/encoding@1",
    "@atproto/api": "npm:@atproto/api@^0.14.9",
    "@atproto/common": "npm:@atproto/common@^0.4.8",
    "@atproto/crypto": "npm:@atproto/crypto@^0.4.4",
    "@atproto/identity": "npm:@atproto/identity@^0.4.8",
    "@atproto/lexicon": "npm:@atproto/lexicon@^0.4.8",
    "@atproto/syntax": "npm:@atproto/syntax@^0.3.4",
    "@sprk/xrpc-server": "jsr:@sprk/xrpc-server@^0.1.5",
    "express": "npm:express@^4.21.2",
    "jose": "npm:jose@^6.0.11",
    "key-encoder": "npm:key-encoder@^2.0.3",
    "mongoose": "npm:mongoose@^8.12.1",
    "multiformats": "npm:multiformats@^9.9.0",
    "p-queue": "npm:p-queue@^8.1.0",
    "pino": "npm:pino@^8.19.0",
    "ws": "npm:ws@^8.18.0"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "hono/jsx"
  },
  "unstable": ["sloppy-imports"]
}
