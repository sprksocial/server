{
  "name": "app",
  "version": "1.0.50",
  "packageManager": "pnpm@8.6.11",
  "scripts": {
    "codegen": "lex gen-server --yes ./src/lexicon ../../lexicons/com/atproto/*/* ../../lexicons/so/sprk/*/*",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc --build tsconfig.json",
    "docker-dev": "docker compose -f compose.dev.yaml up --build --watch",
    "lint": "eslint . --ext .ts --config ../../.eslintrc",
    "format": "prettier --write src/*.ts src/**/*.ts --config ../../.prettierrc --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@atproto/api": "^0.14.9",
    "@atproto/common": "^0.4.8",
    "@atproto/crypto": "^0.4.4",
    "@atproto/identity": "^0.4.6",
    "@atproto/lexicon": "^0.4.8",
    "@atproto/oauth-client-node": "^0.2.12",
    "@atproto/sync": "^0.1.17",
    "@atproto/syntax": "^0.3.4",
    "@atproto/xrpc": "^0.6.10",
    "@atproto/xrpc-server": "^0.7.12",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.4.3",
    "dotenv": "^16.4.7",
    "envalid": "^8.0.0",
    "express": "^4.21.2",
    "hono": "^4.7.4",
    "iron-session": "^8.0.4",
    "lodash": "^4.17.21",
    "mongoose": "^8.12.1",
    "multiformats": "^9.9.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uint8arrays": "^5.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@atproto/lex-cli": "^0.6.2",
    "@types/express": "^5.0.0",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "module": "src/index.js",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "cbor-extract",
      "esbuild"
    ]
  }
}
