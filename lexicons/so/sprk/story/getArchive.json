{
  "lexicon": 1,
  "id": "so.sprk.story.getArchive",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get archived stories for the requesting account. Requires auth.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["stories"],
          "properties": {
            "cursor": { "type": "string" },
            "stories": {
              "type": "array",
              "items": { "type": "ref", "ref": "so.sprk.story.defs#storyView" }
            }
          }
        }
      }
    }
  }
}
