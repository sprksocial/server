{
  "lexicon": 1,
  "id": "so.sprk.authDeleteContent",
  "defs": {
    "main": {
      "type": "permission-set",
      "title": "Delete Spark Content",
      "title:lang": {},
      "detail": "Clean up Spark account history: posts, replies, reposts, likes, thread controls, stories, and audio records.",
      "detail:lang": {},
      "permissions": [
        {
          "type": "permission",
          "resource": "repo",
          "action": ["delete"],
          "collection": [
            "so.sprk.feed.like",
            "so.sprk.feed.post",
            "so.sprk.feed.reply",
            "so.sprk.feed.repost",
            "so.sprk.feed.threadgate",
            "so.sprk.sound.audio",
            "so.sprk.story.post"
          ]
        }
      ]
    }
  }
}
